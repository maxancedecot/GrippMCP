{
  "name": "gripp-mcp",
  "version": "0.1.2",
  "description": "Model Context Protocol server for the Gripp API 3.0 JSON-RPC endpoint.",
  "type": "module",
  "bin": {
    "gripp-mcp": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "src/generated/gripp_api_metadata.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:vercel": "next build",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js",
    "fetch:metadata": "node scripts/fetch-gripp-metadata.mjs",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
